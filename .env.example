# THE V2 PROJECT — Variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# El archivo .env NUNCA debe subirse al repositorio.

# ---- Supabase (Frontend) ----
# Obtenidos en: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ---- Supabase Edge Function Secrets ----
# Configurar con: supabase secrets set NOMBRE=valor
# (NO van en este archivo — son secrets del servidor)
#
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   (auto-disponible en Edge Functions)
# ANTHROPIC_API_KEY=sk-ant-...       (supabase secrets set ANTHROPIC_API_KEY=...)
